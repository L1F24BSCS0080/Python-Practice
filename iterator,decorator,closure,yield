# generator   auto iterator
#iterator move to yield values/points
def square(n):
    a=0
    for i in range(n):
        yield (a*a)
        a+=1
def febo(n):
    a=0
    b=1
    for _ in range(n):
        yield a
        a,b=b,a+b
        
for x in febo(8):
    print(x,end="")
print()

for x in square(5):
    print(x,end="");
    
