#decorator
#act as a wrapper on a function
#use case= find execution time
import time
def timer(func):
     def wrapper(*args,**kwargs):
         before=time.time()
         result=func(*args,**kwargs)
         after=time.time()
         print("execution time:",after-before)
         return result
     return wrapper
@timer
def calculate():
    total = 0

    for i in range(1000000):
        total += i

calculate()

def dec(func):
    def wrapper(hi):
        print("staring function")
        func(hi)
        print("ending function")
    return wrapper
@dec
def greet(hi):
    print("welcome ASAD")
    
